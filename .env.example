# PostgreSQL connection string — host=db matches the docker-compose service name
DATABASE_URL=postgresql://investments_user:CHANGE_ME@db:5432/investments

# Random secret key for itsdangerous session signing — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_32_RANDOM_BYTES

# bcrypt hash of admin password — generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-CHANGE_ME

# Freedom Finance (freedom24.com = tradernet.com) — API keys from tradernet.com profile
FREEDOM_PUBLIC_KEY=CHANGE_ME
FREEDOM_PRIVATE_KEY=CHANGE_ME
FREEDOM_LOGIN=CHANGE_ME_EMAIL
FREEDOM_PASSWORD=CHANGE_ME_PASSWORD

# Telegram bot token — obtain from @BotFather
TELEGRAM_BOT_TOKEN=CHANGE_ME
# Your personal Telegram chat ID — forward a message to @userinfobot to find it
TELEGRAM_CHAT_ID=CHANGE_ME

# Error tracking — self-hosted GlitchTip at glitchtip.semishan.pro
SENTRY_DSN=
